{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaveep.local/sia/schemas/recommendation-report.schema.json",
  "title": "KAVEEP-SIA Recommendation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generatedAt",
    "scanTarget",
    "summary",
    "recommendations",
    "protectedItems",
    "doNotTouch",
    "errors"
  ],
  "properties": {
    "generatedAt": { "type": "string", "format": "date-time" },
    "scanTarget": { "type": "string" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalRecommendations",
        "lowRiskCount",
        "mediumRiskCount",
        "highRiskCount",
        "protectedCount",
        "unknownCount"
      ],
      "properties": {
        "totalRecommendations": { "type": "integer", "minimum": 0 },
        "lowRiskCount": { "type": "integer", "minimum": 0 },
        "mediumRiskCount": { "type": "integer", "minimum": 0 },
        "highRiskCount": { "type": "integer", "minimum": 0 },
        "protectedCount": { "type": "integer", "minimum": 0 },
        "unknownCount": { "type": "integer", "minimum": 0 }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation" }
    },
    "protectedItems": {
      "type": "array",
      "items": { "$ref": "#/$defs/protectedItem" }
    },
    "doNotTouch": {
      "type": "array",
      "items": { "$ref": "#/$defs/protectedItem" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/error" }
    }
  },
  "$defs": {
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "type",
        "riskLevel",
        "reason",
        "suggestedAction",
        "manualReviewRequired",
        "automaticCleanupAllowed"
      ],
      "properties": {
        "path": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "safe_to_review",
            "likely_temporary",
            "likely_installer",
            "likely_duplicate_candidate",
            "large_file_review",
            "old_file_review",
            "archive_candidate",
            "keep_protected",
            "do_not_touch",
            "needs_user_confirmation",
            "unknown_review_required"
          ]
        },
        "riskLevel": { "$ref": "#/$defs/riskLevel" },
        "reason": { "type": "string" },
        "suggestedAction": { "type": "string" },
        "manualReviewRequired": { "type": "boolean" },
        "automaticCleanupAllowed": { "type": "boolean" },
        "status": { "$ref": "#/$defs/status" }
      }
    },
    "protectedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "reason", "riskLevel"],
      "properties": {
        "path": { "type": "string" },
        "reason": { "type": "string" },
        "riskLevel": { "$ref": "#/$defs/riskLevel" },
        "status": { "$ref": "#/$defs/status" }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "path": { "type": "string" },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "status": { "$ref": "#/$defs/status" }
      }
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high", "protected", "unknown"]
    },
    "status": {
      "type": "string",
      "enum": ["advisory_only", "protected", "do_not_touch", "blocked", "needs_more_review", "UNVERIFIED"]
    }
  }
}

